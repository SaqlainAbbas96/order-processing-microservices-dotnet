{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "orders-root": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "inventory-root": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/products" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      }
    },
    "Clusters": {
      "orders-cluster": {
        "Destinations": { "d1": { "Address": "http://order-service:8080/" } }
      },
      "inventory-cluster": {
        "Destinations": { "d1": { "Address": "http://inventory-service:8081/" } }
      }
    }
  },
  "AllowedHosts": "*"
}
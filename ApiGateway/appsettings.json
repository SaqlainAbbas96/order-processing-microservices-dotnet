{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "orders-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5021/"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5201/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
